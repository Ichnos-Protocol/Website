{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://$VITE_API_HOST/api/$1",
      "env": ["VITE_API_HOST"]
    }
  ],
  "redirects": [
    { "source": "/data", "destination": "/passport", "statusCode": 301 },
    { "source": "/catena-x", "destination": "/passport", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
