{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/api" }
  ],
  "crons": [
    { "path": "/api/admin/retention-sweep", "schedule": "0 2 * * 0" },
    { "path": "/api/admin/notifications/digest", "schedule": "0 9 * * *" }
  ]
}
